apiVersion: v1
kind: Secret
metadata:
  name: patent-secrets
  namespace: patent-platform
type: Opaque
stringData:
  database-url: "postgresql+asyncpg://user:password@postgres:5432/patent_platform"
  secret-key: "your-secret-key-here"
  openai-api-key: "sk-your-openai-api-key"
  neo4j-password: "your-neo4j-password"
